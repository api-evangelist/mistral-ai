{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/Tool",
  "title": "Tool",
  "type": "object",
  "required": [
    "type",
    "function"
  ],
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "function"
      ],
      "description": "The type of the tool. Currently only function is supported."
    },
    "function": {
      "$ref": "#/components/schemas/FunctionDefinition"
    }
  }
}