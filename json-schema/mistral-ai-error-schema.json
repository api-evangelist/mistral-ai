{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/Error",
  "title": "Error",
  "type": "object",
  "properties": {
    "message": {
      "type": "string",
      "description": "A human-readable error message."
    },
    "type": {
      "type": "string",
      "description": "The type of error."
    },
    "code": {
      "type": "integer",
      "description": "The HTTP status code."
    }
  }
}