{
  "opencollection": "1.0.0",
  "info": {
    "name": "Mistral AI Batch API",
    "version": "1.0.0"
  },
  "request": {
    "auth": {
      "type": "bearer",
      "token": "{{bearerToken}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "Batch Jobs",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "List batch jobs",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.mistral.ai/v1/batch/jobs",
            "params": [
              {
                "name": "page",
                "value": "",
                "type": "query",
                "description": "The page number for pagination."
              },
              {
                "name": "page_size",
                "value": "",
                "type": "query",
                "description": "The number of items per page."
              }
            ]
          },
          "docs": "List all batch jobs for the organization. Returns a paginated list of jobs with their current status and progress information."
        },
        {
          "info": {
            "name": "Create batch job",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.mistral.ai/v1/batch/jobs",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Creates a new batch job for asynchronous processing. The job will be queued and processed in the background. Supports inline requests or file-based batching for chat completions, embeddings, FIM completions, moderations, OCR, classifications, and audio transcriptions."
        },
        {
          "info": {
            "name": "Get batch job",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.mistral.ai/v1/batch/jobs/:job_id",
            "params": [
              {
                "name": "job_id",
                "value": "",
                "type": "path",
                "description": "The ID of the batch job."
              }
            ]
          },
          "docs": "Retrieve information about a specific batch job including its status, progress, and output file location."
        },
        {
          "info": {
            "name": "Cancel batch job",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.mistral.ai/v1/batch/jobs/:job_id/cancel",
            "params": [
              {
                "name": "job_id",
                "value": "",
                "type": "path",
                "description": "The ID of the batch job."
              }
            ]
          },
          "docs": "Request the cancellation of a batch job. The job will be cancelled if it has not already completed."
        }
      ]
    }
  ],
  "bundled": true
}