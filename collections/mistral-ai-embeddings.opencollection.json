{
  "opencollection": "1.0.0",
  "info": {
    "name": "Mistral AI Embeddings API",
    "version": "1.0.0"
  },
  "request": {
    "auth": {
      "type": "bearer",
      "token": "{{bearerToken}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "Embeddings",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Create embeddings",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.mistral.ai/v1/embeddings",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Creates an embedding vector representing the input text. The input can be a single string or an array of strings for batch processing. Returns high-dimensional vector representations suitable for semantic search, clustering, and classification tasks."
        }
      ]
    }
  ],
  "bundled": true
}