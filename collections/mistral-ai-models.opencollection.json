{
  "opencollection": "1.0.0",
  "info": {
    "name": "Mistral AI Models API",
    "version": "1.0.0"
  },
  "request": {
    "auth": {
      "type": "bearer",
      "token": "{{bearerToken}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "Models",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "List models",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.mistral.ai/v1/models"
          },
          "docs": "List all models available to the user, including base models and fine-tuned models. Returns model IDs, capabilities, and metadata."
        },
        {
          "info": {
            "name": "Retrieve model",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.mistral.ai/v1/models/:model_id",
            "params": [
              {
                "name": "model_id",
                "value": "",
                "type": "path",
                "description": "The ID of the model."
              }
            ]
          },
          "docs": "Retrieves a model instance, providing information about the model including its ID, creation date, owner, and capabilities."
        },
        {
          "info": {
            "name": "Delete model",
            "type": "http"
          },
          "http": {
            "method": "DELETE",
            "url": "https://api.mistral.ai/v1/models/:model_id",
            "params": [
              {
                "name": "model_id",
                "value": "",
                "type": "path",
                "description": "The ID of the model."
              }
            ]
          },
          "docs": "Delete a fine-tuned model. Only models owned by the user's organization can be deleted. Base models cannot be deleted."
        },
        {
          "info": {
            "name": "Update fine-tuned model",
            "type": "http"
          },
          "http": {
            "method": "PATCH",
            "url": "https://api.mistral.ai/v1/fine_tuning/models/:model_id",
            "params": [
              {
                "name": "model_id",
                "value": "",
                "type": "path",
                "description": "The ID of the model."
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Update a fine-tuned model's metadata such as its name or description."
        }
      ]
    }
  ],
  "bundled": true
}